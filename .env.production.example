# 一课一练 · Quiz App — Production Environment Variables
# ==========================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git!

# DeepSeek API key (required for AI question generation & explanation)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# JWT signing secret — generate a random 64-char string:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-this-to-a-random-secret-string

# JWT token expiry in hours (default 720 = 30 days)
JWT_EXPIRATION_HOURS=720

# SQLite database path (absolute path inside container)
DATABASE_URL=sqlite:////app/data/quiz.db

# Domain for SSL (used by setup-ssl.sh)
DOMAIN=quiz.yourdomain.com

# Cloudflare API token for DDNS (only needed if using Cloudflare Tunnel)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone:DNS:Edit
CF_API_TOKEN=
